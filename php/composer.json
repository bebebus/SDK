{
    "name": "bebebus/merchant-openapi-sdk",
    "description": "商户支付 OpenAPI 的 PHP 8 SDK（零第三方依赖，仅用标准库与 ext-curl）",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/bebebus/SDK",
    "keywords": ["payment", "openapi", "merchant", "sdk"],
    "support": {
        "issues": "https://github.com/bebebus/SDK/issues",
        "source": "https://github.com/bebebus/SDK"
    },
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Merchant\\Openapi\\": "src/"
        }
    }
}
